---
interface Props {
  title: string;
  date: Date;
  description?: string;
}

const { title, date, description } = Astro.props;
const formatted = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title} — Aleena Siji</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: Charter, 'Bitstream Charter', 'Sitka Text', Cambria, Georgia, serif;
        font-size: 18px;
        line-height: 1.7;
        color: #222;
        background: #fff;
      }

      .wrapper {
        max-width: 680px;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
      }

      a { color: rgb(13, 60, 120); text-decoration: none; }
      a:hover { text-decoration: underline; }

      .back {
        font-size: 0.9rem;
        margin-bottom: 2.5rem;
        display: block;
      }

      h1 {
        font-size: 1.7rem;
        font-weight: normal;
        line-height: 1.3;
        margin-bottom: 0.4rem;
      }

      .date {
        font-size: 0.9rem;
        color: #888;
        margin-bottom: 2.5rem;
      }

      .content p { margin-bottom: 1.1rem; }
      .content h2 { font-size: 1.2rem; margin: 2rem 0 0.75rem; }
      .content h3 { font-size: 1rem; font-weight: bold; margin: 1.5rem 0 0.5rem; }
      .content ul, .content ol { padding-left: 1.5rem; margin-bottom: 1rem; }
      .content li { margin-bottom: 0.3rem; }
      .content code {
        font-family: 'SFMono-Regular', Consolas, monospace;
        font-size: 0.85em;
        background: #f4f4f4;
        padding: 0.1em 0.3em;
        border-radius: 3px;
      }
      .content pre {
        background: #f4f4f4;
        padding: 1rem;
        border-radius: 4px;
        overflow-x: auto;
        margin-bottom: 1rem;
      }
      .content pre code { background: none; padding: 0; }
      .content blockquote {
        border-left: 3px solid #ddd;
        padding-left: 1rem;
        color: #555;
        margin-bottom: 1rem;
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <a class="back" href="/">← Aleena Siji</a>
      <h1>{title}</h1>
      <div class="date">{formatted}</div>
      <div class="content">
        <slot />
      </div>
    </div>
  </body>
</html>

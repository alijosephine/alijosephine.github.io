---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Aleena Siji — ML Engineer and Researcher at Helmholtz Munich." />
    <title>Aleena Siji</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: Charter, 'Bitstream Charter', 'Sitka Text', Cambria, Georgia, serif;
        font-size: 18px;
        line-height: 1.7;
        color: #222;
        background: #fff;
        max-width: 680px;
        margin: 0 auto;
        padding: 4rem 1.5rem 7rem;
      }

      a { color: rgb(13, 60, 120); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* Header */
      h1 {
        font-size: 2.1rem;
        font-weight: normal;
        margin-bottom: 0.15rem;
      }

      .nav-links {
        font-size: 0.9rem;
        margin-top: 0.4rem;
        margin-bottom: 1.6rem;
      }

      .nav-links a { margin-right: 1.2rem; }

      /* Sections */
      section { margin-top: 2.8rem; }

      h2 {
        font-size: 0.78rem;
        font-weight: bold;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #999;
        margin-bottom: 1.1rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid #eee;
      }

      p { margin-bottom: 0.9rem; }
      p:last-child { margin-bottom: 0; }

      /* Publications */
      .pub-list { list-style: none; }

      .pub {
        margin-bottom: 1.4rem;
      }

      .pub-title { font-style: italic; }

      .pub-authors {
        font-size: 0.88rem;
        color: #555;
        margin-top: 0.15rem;
      }

      .pub-meta {
        font-size: 0.88rem;
        color: #666;
        margin-top: 0.1rem;
      }

      .pub-meta .venue { font-weight: bold; color: #444; }

      .pub-meta .tag {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: normal;
        font-style: normal;
        background: #f0f0f0;
        color: #555;
        border-radius: 3px;
        padding: 0.05em 0.45em;
        margin-left: 0.3rem;
        vertical-align: middle;
      }

      /* Projects */
      .project { margin-bottom: 1.1rem; }
      .project-name { font-weight: bold; }
      .project-desc { color: #555; }

      /* Blog */
      .blog-list { list-style: none; }

      .blog-list li {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.45rem;
      }

      .blog-list .date {
        font-size: 0.88rem;
        color: #bbb;
        white-space: nowrap;
        margin-left: 1.5rem;
        font-family: 'SFMono-Regular', Consolas, monospace;
      }

      .coming-soon {
        color: #aaa;
        font-style: italic;
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>

    <h1>Aleena Siji</h1>
    <div class="nav-links">
      <a href="https://github.com/alijosephine" target="_blank" rel="noopener">GitHub</a>
      <a href="https://linkedin.com/in/aleena-josephine-siji" target="_blank" rel="noopener">LinkedIn</a>
    </div>

    <section id="bio">
      <h2>About</h2>
      <p>
        I am an ML Engineer and Researcher at
        <a href="https://www.helmholtz-munich.de" target="_blank" rel="noopener">Helmholtz Munich</a>,
        affiliated with <a href="https://www.helmholtz.ai" target="_blank" rel="noopener">Helmholtz AI</a>
        and <a href="https://www.tum.de" target="_blank" rel="noopener">TU Munich</a>.
        My research focuses on foundation models for biological data, generative modeling,
        and representation learning.
      </p>
      <p>
        Previously, I worked at
        <a href="https://www.cispa.de" target="_blank" rel="noopener">CISPA Helmholtz Center for Information Security</a>,
        Intuit, and Interview Kickstart.
      </p>
    </section>

    <section id="publications">
      <h2>Publications</h2>
      <ul class="pub-list">

        <li class="pub">
          <div class="pub-title">From Words to Amino Acids: Does the Curse of Depth persist?</div>
          <div class="pub-authors"><strong>A. Siji</strong>, A. Mamaghan, F. Kapl, T. H&ouml;ppe, E. Angelis, A. Dittadi, M. Brenner, M. Heinzinger, K. Johansson, K. Maile, J. Oswald, S. Bauer</div>
          <div class="pub-meta">
            <span class="venue">ICLR 2026</span> Workshop on Learning Meaningful Representations of Life (LMRL'26)
            <span class="tag">Poster</span>
          </div>
        </li>

        <li class="pub">
          <div class="pub-title">SEQRET: Mining Rule Sets from Event Sequences</div>
          <div class="pub-authors"><strong>A. Siji</strong>, J. C&uuml;ppers, O. Mian, and J. Vreeken</div>
          <div class="pub-meta">
            <span class="venue">AAAI 2026</span> &middot; 40th Annual Conference on Artificial Intelligence
            <span class="tag">Oral</span>
          </div>
        </li>

        <li class="pub">
          <div class="pub-title">Iterative Oversubscription Planning with Goal-Conflict Explanations</div>
          <div class="pub-authors">R. Eifler, D. Fi&scaron;er, <strong>A. Siji</strong>, and J. Hoffmann</div>
          <div class="pub-meta">
            <span class="venue">ECAI 2024</span> &middot; 27th European Conference on Artificial Intelligence
            <span class="tag">Poster</span>
          </div>
        </li>

      </ul>
    </section>

    <section id="projects">
      <h2>Projects</h2>

      <div class="project">
        <div class="project-name">Accessible Android Keyboard for Parkinson's Patients</div>
        <div class="project-desc">
          Custom Android keyboard with a scanning grid layout, single-tap selection and personalized next-word prediction (built from scratch) to improve accessibility for users with Parkinson's disease.
        </div>
      </div>

      <div class="project">
        <div class="project-name">Electronic Board Games with Arduino</div>
        <div class="project-desc">
          Physical board games (Snake and Ladder, Ludo) with LED circuits controlled by an Arduino microcontroller to illuminate player movement in real time.
        </div>
      </div>

    </section>

    <section id="blog">
      <h2>Writing</h2>
      {posts.length > 0 ? (
        <ul class="blog-list">
          {posts.map(post => (
            <li>
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
              <span class="date">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="coming-soon">Coming soon.</p>
      )}
    </section>

  </body>
</html>

---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Aleena Siji — ML Engineer and Researcher at Helmholtz Munich." />
    <title>Aleena Siji</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: Charter, 'Bitstream Charter', 'Sitka Text', Cambria, Georgia, serif;
        font-size: 18px;
        line-height: 1.7;
        color: #222;
        background: #fff;
      }

      .wrapper {
        max-width: 680px;
        margin: 0 auto;
        padding: 4rem 2rem 7rem;
      }

      a { color: rgb(13, 60, 120); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* Header */
      h1 {
        font-size: 2.1rem;
        font-weight: normal;
        margin-bottom: 0.15rem;
      }

      .nav-links {
        font-size: 0.9rem;
        margin-top: 0.4rem;
        margin-bottom: 1.6rem;
      }

      .nav-links a { margin-right: 1.2rem; }

      /* Sections */
      section { margin-top: 2.8rem; }

      h2 {
        font-size: 0.78rem;
        font-weight: bold;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #999;
        margin-bottom: 1.1rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid #eee;
      }

      p { margin-bottom: 0.9rem; }
      p:last-child { margin-bottom: 0; }

      /* Blog */
      .blog-list { list-style: none; }

      .blog-list li {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.45rem;
      }

      .blog-list .date {
        font-size: 0.88rem;
        color: #bbb;
        white-space: nowrap;
        margin-left: 1.5rem;
        font-family: 'SFMono-Regular', Consolas, monospace;
      }

      .coming-soon {
        color: #aaa;
        font-style: italic;
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <div class="wrapper">

    <h1>Aleena Siji</h1>
    <div class="nav-links">
      <a href="https://github.com/alijosephine" target="_blank" rel="noopener">GitHub</a>
      <a href="https://linkedin.com/in/aleena-josephine-siji" target="_blank" rel="noopener">LinkedIn</a>
    </div>

    <section id="bio">
      <h2>About</h2>
      <p>
        I am an ML Engineer and Researcher at
        <a href="https://www.helmholtz-munich.de" target="_blank" rel="noopener">Helmholtz Munich</a>,
        affiliated with <a href="https://www.helmholtz.ai" target="_blank" rel="noopener">Helmholtz AI</a>
        and <a href="https://www.tum.de" target="_blank" rel="noopener">TU Munich</a>.
        Previously, I worked at
        <a href="https://www.cispa.de" target="_blank" rel="noopener">CISPA</a>,
        <a href="https://www.intuit.com" target="_blank" rel="noopener">Intuit</a>, and
        <a href="https://www.interviewkickstart.com" target="_blank" rel="noopener">Interview Kickstart</a>.
      </p>
    </section>

    <section id="blog">
      <h2>Writing</h2>
      {posts.length > 0 ? (
        <ul class="blog-list">
          {posts.map(post => (
            <li>
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
              <span class="date">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="coming-soon">Coming soon.</p>
      )}
    </section>

    </div>
  </body>
</html>
